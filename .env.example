# Copy this to .env.local for local development
# Do NOT commit this file to GitHub

# PostgreSQL Connection String (get from Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/event_management

# Optional direct IP fallback for Vercel if DNS resolution fails
# DB_HOST_IP=123.45.67.89
# DB_PORT=6543
# DB_PASSWORD=your_password
# DB_NAME=postgres
# DB_SSL_MODE=disable

# Environment
NODE_ENV=development
